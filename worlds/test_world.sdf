<?xml version="1.0" ?>
<sdf version="1.9">

<world name="manipulation_world">

	<plugin
  filename="gz-sim-sensors-system"
  name="gz::sim::systems::Sensors">
  <render_engine>ogre2</render_engine>
</plugin>


	<light name="sun" type="directional">
  <cast_shadows>true</cast_shadows>

  <pose>0 0 10 0 0 0</pose>

  <diffuse>1 1 1 1</diffuse>
  <specular>0.5 0.5 0.5 1</specular>

  <direction>-0.5 0.1 -1</direction>
</light>

  <model name="ground">
    <static>true</static>

    <link name="link">

      <collision name="collision">
        <geometry>
          <box>
            <size>20 20 0.1</size>
          </box>
        </geometry>
      </collision>

      <visual name="visual">
        <geometry>
          <box>
            <size>20 20 0.1</size>
          </box>
        </geometry>
      </visual>

    </link>
  </model>

  <model name="table">

  <static>true</static>

  <pose>0 0 0.75 0 0 0</pose>

  <link name="link">

    <collision name="collision">
      <geometry>
        <box>
          <size>2 2 0.1</size>
        </box>
     </geometry>
    </collision>

    <visual name="visual">
      <geometry>
        <box>
          <size>1.2 0.8 0.05</size>
        </box>
      </geometry>
    </visual>

  </link>

</model>

	<model name="cube_1">
  <pose>0.2 0 0.9 0 0 0</pose>
  <link name="link">
    <collision name="collision">
      <geometry>
        <box>
          <size>0.08 0.08 0.08</size>
        </box>
      </geometry>
    </collision>
    <visual name="visual">
      <geometry>
        <box>
          <size>0.08 0.08 0.08</size>
        </box>
      </geometry>
    </visual>
  </link>
</model>
	

	<model name="cube_2">
  <pose>-0.2 0.1 0.9 0 0 0</pose>
  <link name="link">
    <collision name="collision">
      <geometry>
        <box>
          <size>0.09 0.09 0.09</size>
        </box>
      </geometry>
    </collision>
    <visual name="visual">
      <geometry>
        <box>
          <size>0.09 0.09 0.09</size>
        </box>
      </geometry>
    </visual>
  </link>
</model>	


	<model name="cube_3">
  <pose>0.1 0.2 0.9 0 0 0</pose>
  <link name="link">
    <collision name="collision">
      <geometry>
        <box>
          <size>0.07 0.07 0.07</size>
        </box>
      </geometry>
    </collision>
    <visual name="visual">
      <geometry>
        <box>
          <size>0.07 0.07 0.07</size>
        </box>
      </geometry>
    </visual>
  </link>
</model>



	<model name="cube_4">
  <pose>-0.1 -0.2 0.9 0 0 0</pose>
  <link name="link">
    <collision name="collision">
      <geometry>
        <box>
          <size>0.06 0.06 0.12</size>
        </box>
      </geometry>
    </collision>
    <visual name="visual">
      <geometry>
        <box>
          <size>0.06 0.06 0.12</size>
        </box>
      </geometry>
    </visual>
  </link>
</model>



	<model name="cube_5">
  <pose>0 0.15 0.9 0 0 0</pose>
  <link name="link">
    <collision name="collision">
      <geometry>
        <box>
          <size>0.1 0.05 0.08</size>
        </box>
      </geometry>
    </collision>
    <visual name="visual">
      <geometry>
        <box>
          <size>0.1 0.05 0.08</size>
        </box>
      </geometry>
    </visual>
  </link>
</model>





</world>

</sdf>
